<section class="page-header" style="background-image: url('/images/rivver.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <h1>Contact Us</h1>
        <p>Get Your Free Tree Service Estimate Today</p>
    </div>
</section>

<section class="contact-section section-padding">
    <div class="container">
        <div class="contact-grid">
            <div class="contact-info">
                <h2>JT & Sons Tree Service LLC</h2>
                <p>P.O. Box 1433<br>Gold Beach, OR 97444</p>
                <p><i class="fas fa-phone-alt"></i> Office: <a href="tel:<%= sitePhone %>"><%= sitePhone %></a></p>
                <p><i class="fas fa-mobile-alt"></i> Cell/Text: <a href="tel:<%= siteCell %>"><%= siteCell %></a></p>
                <p><i class="fas fa-envelope"></i> Email: <a href="mailto:<%= siteEmail %>"><%= siteEmail %></a></p>
                <p><i class="fas fa-certificate"></i> CCB License #: <%= ccbLicense %></p>
                <p><strong>Powerline Clearance Certified</strong><br>Licensed, Insured & Bonded</p>
            </div>
            <div class="contact-form">
                <h2>Send Us a Message</h2>
                <% if (locals.contactError) { %>
                    <div class="alert alert-error"><%= contactError %></div>
                <% } %>
                <% if (locals.contactSuccess) { %>
                    <div class="alert alert-success"><%= contactSuccess %></div>
                <% } %>
                <form action="/contact" method="POST">
                    <div class="form-group">
                        <label for="name">Name *</label>
                        <input type="text" id="name" name="name" required value="<%= locals.contactData?.name || '' %>">
                    </div>
                    <div class="form-group">
                        <label for="email">Email *</label>
                        <input type="email" id="email" name="email" required value="<%= locals.contactData?.email || '' %>">
                    </div>
                    <div class="form-group">
                        <label for="phone">Phone</label>
                        <input type="tel" id="phone" name="phone" value="<%= locals.contactData?.phone || '' %>">
                    </div>
                    <div class="form-group">
                        <label for="message">Message *</label>
                        <textarea id="message" name="message" rows="5" required><%= locals.contactData?.message || '' %></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Send Message</button>
                </form>
            </div>
        </div>

        <!-- Quote Request Section -->
        <div class="quote-section" id="quote" style="margin-top: 50px;">
            <h2>Request a Free Quote</h2>
            <p>Tell us about your tree care needs and we'll get back to you with a free estimate.</p>
            <%- include('../partials/quote-form') %>
        </div>
    </div>
</section>