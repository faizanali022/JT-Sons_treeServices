<%
// Brookings Tree Trimming
%>

<!-- Page Header -->
<section class="page-header" style="background-image: url('/images/treaming2.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <h1>Tree Trimming in Brookings, OR</h1>
        <p>Professional Tree Pruning & Tree Maintenance</p>
    </div>
</section>

<!-- Main Content -->
<section class="area-service-content section-padding">
    <div class="container">
        <!-- Intro with Image -->
        <div class="service-intro">
            <div class="intro-text">
                <p>JT & Sons Tree Service LLC offers expert tree trimming services in Brookings, Oregon to help maintain healthy, safe, and beautiful trees.</p>
                <p>Regular trimming helps remove dead branches, improve tree structure, and reduce the risk of falling limbs during storms. Our team provides precise pruning and trimming to maintain the health and appearance of your trees.</p>
            </div>
            <div class="intro-image">
                <img src="/images/tree-trimming.jpg" alt="Tree Trimming in Brookings" class="rounded-image">
            </div>
        </div>

        <!-- Services List -->
        <div class="content-container">
            <h2>Our Tree Trimming Services in Brookings Include:</h2>
            <ul>
                <li>Tree pruning and shaping</li>
                <li>Deadwood removal</li>
                <li>Tree thinning</li>
                <li>Limb removal</li>
                <li>Storm damage trimming</li>
                <li>Preventative maintenance trimming</li>
            </ul>
        </div>

        <!-- Contact Info -->
        <div class="contact-info-box">
            <h3>Call today for a free estimate</h3>
            <p>
                <i class="fas fa-phone-alt"></i> Office: <a href="tel:<%= sitePhone %>"><%= sitePhone %></a><br>
                <i class="fas fa-mobile-alt"></i> Cell/Text: <a href="tel:<%= siteCell %>"><%= siteCell %></a>
            </p>
        </div>
    </div>
</section>