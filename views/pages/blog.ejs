<section class="page-header" style="background-image: url('/images/tree-trimming.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <h1>Tree Care Blog</h1>
        <p>Tips, News & Insights from JT & Sons Tree Service</p>
    </div>
</section>

<section class="blog-listing section-padding">
    <div class="container">
        <div class="blog-grid">
            <% if (locals.posts && posts.length > 0) { %>
                <% posts.forEach(post => { %>
                    <article class="blog-card">
                        <div class="blog-image" style="background-image: url('<%= post.featuredImage || '/images/def.jpg' %>');"></div>
                        <div class="blog-content">
                            <h2><a href="/blog/<%= post.slug %>"><%= post.title %></a></h2>
                            <p class="post-meta">
                                <%= new Date(post.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }) %> 
                                | by <%= post.author || 'JT & Sons' %>
                            </p>
                            <p><%= post.excerpt || post.content.substring(0,150) + '…' %></p>
                            <a href="/blog/<%= post.slug %>" class="read-more">Read More <i class="fas fa-arrow-right"></i></a>
                        </div>
                    </article>
                <% }) %>
            <% } else { %>
                <div class="no-posts">
                    <p>No blog posts yet. Check back soon for tree care tips and updates!</p>
                </div>
            <% } %>
        </div>
    </div>
</section>