<%
// Brookings Fire Reduction
%>

<!-- Page Header -->
<section class="page-header" style="background-image: url('/images/fire-redictionn.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <h1>Fire Reduction & View Clearing in Brookings, OR</h1>
        <p>Defensible Space, Brush Clearing & Wildfire Prevention</p>
    </div>
</section>

<!-- Main Content -->
<section class="area-service-content section-padding">
    <div class="container">
        <!-- Intro with Image -->
        <div class="service-intro">
            <div class="intro-text">
                <p>JT & Sons Tree Service LLC provides fast and reliable emergency tree services in Brookings, Oregon. Coastal storms and strong winds can cause trees or branches to fall unexpectedly. Our team responds quickly to handle storm damage cleanup, hazardous tree removal, and emergency tree trimming.</p>
                <p>We also offer view clearing and fire reduction services to help homeowners reduce wildfire risk and maintain defensible space around their property.</p>
            </div>
            <div class="intro-image">
                <img src="/images/fire-reduction.jpg" alt="Fire Reduction in Brookings" class="rounded-image">
            </div>
        </div>

        <!-- Services List -->
        <div class="content-container">
            <h2>Our Emergency & Fire Reduction Services Include:</h2>
            <ul>
                <li>Emergency tree removal</li>
                <li>Storm damage cleanup</li>
                <li>Fallen tree removal</li>
                <li>Hazardous limb removal</li>
                <li>Brush clearing</li>
                <li>Defensible space creation</li>
                <li>View clearing for coastal properties</li>
            </ul>
            <p>If you need emergency tree service near Brookings OR, JT & Sons Tree Service LLC is ready to help.</p>
        </div>

        <!-- Contact Info -->
        <div class="contact-info-box">
            <h3>Call today for a free estimate</h3>
            <p>
                <i class="fas fa-phone-alt"></i> Office: <a href="tel:<%= sitePhone %>"><%= sitePhone %></a><br>
                <i class="fas fa-mobile-alt"></i> Cell/Text: <a href="tel:<%= siteCell %>"><%= siteCell %></a>
            </p>
        </div>
    </div>
</section>