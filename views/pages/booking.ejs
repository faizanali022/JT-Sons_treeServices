<section class="page-header" style="background-image: url('/images/about-bg.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <h1>Book a Consultation</h1>
        <p>Schedule your free, no-obligation consultation</p>
    </div>
</section>

<section class="booking-form-section section-padding">
    <div class="container">
        <% if (locals.error) { %>
            <div class="alert alert-error"><%= error %></div>
        <% } %>
        <% if (locals.success) { %>
            <div class="alert alert-success"><%= success %></div>
        <% } %>
        <form action="/booking" method="POST" class="booking-form">
            <div class="form-grid">
                <div class="form-group">
                    <label for="name">Full Name *</label>
                    <input type="text" id="name" name="name" required value="<%= locals.bookingData?.name || '' %>">
                </div>
                <div class="form-group">
                    <label for="email">Email *</label>
                    <input type="email" id="email" name="email" required value="<%= locals.bookingData?.email || '' %>">
                </div>
                <div class="form-group">
                    <label for="phone">Phone Number *</label>
                    <input type="tel" id="phone" name="phone" required value="<%= locals.bookingData?.phone || '' %>">
                </div>
                <div class="form-group">
                    <label for="serviceType">Service Needed *</label>
                    <select id="serviceType" name="serviceType" required>
                        <option value="">Select a service</option>
                        <option value="Tree Removal" <%= locals.bookingData?.serviceType === 'Tree Removal' ? 'selected' : '' %>>Tree Removal</option>
                        <option value="Tree Trimming" <%= locals.bookingData?.serviceType === 'Tree Trimming' ? 'selected' : '' %>>Tree Trimming</option>
                        <option value="Stump Grinding" <%= locals.bookingData?.serviceType === 'Stump Grinding' ? 'selected' : '' %>>Stump Grinding</option>
                        <option value="Fire Reduction" <%= locals.bookingData?.serviceType === 'Fire Reduction' ? 'selected' : '' %>>Fire Reduction</option>
                        <option value="Emergency Tree" <%= locals.bookingData?.serviceType === 'Emergency Tree' ? 'selected' : '' %>>Emergency Tree</option>
                        <option value="Crane Services" <%= locals.bookingData?.serviceType === 'Crane Services' ? 'selected' : '' %>>Crane Services</option>
                        <option value="Consultation" <%= locals.bookingData?.serviceType === 'Consultation' ? 'selected' : '' %>>General Consultation</option>
                    </select>
                </div>
                <div class="form-group">
                    <label for="preferredDate">Preferred Date</label>
                    <input type="date" id="preferredDate" name="preferredDate" value="<%= locals.bookingData?.preferredDate || '' %>">
                </div>
                <div class="form-group full-width">
                    <label for="address">Property Address</label>
                    <input type="text" id="address" name="address" placeholder="Street, City, ZIP" value="<%= locals.bookingData?.address || '' %>">
                </div>
                <div class="form-group full-width">
                    <label for="message">Additional Details</label>
                    <textarea id="message" name="message" rows="4"><%= locals.bookingData?.message || '' %></textarea>
                </div>
            </div>
            <button type="submit" class="btn btn-primary">Submit Booking</button>
        </form>
    </div>
</section>