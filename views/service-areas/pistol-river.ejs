<%
// Pistol River Service Area
%>

<!-- Page Header -->
<section class="page-header" style="background-image: url('/images/pistol-river.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <h1>Tree Service in Pistol River, OR</h1>
        <p>Professional Tree Removal, Tree Trimming & Fire Reduction</p>
    </div>
</section>

<!-- Main Content -->
<section class="area-content section-padding">
    <div class="container">
        <!-- Intro with Image -->
        <div class="service-intro">
            <div class="intro-text">
                <p>JT & Sons Tree Service LLC provides reliable and professional tree services in Pistol River, OR and throughout the Southern Oregon Coast. With over 30 years of experience, our family-owned company specializes in tree removal, tree trimming, stump grinding, emergency services, and fire reduction for residential and commercial properties.</p>
                <p>Pistol River's coastal environment and mature trees can create hazards due to storms, strong winds, or aging trees. Our experienced crew provides safe and efficient tree care to protect your property while preserving the natural beauty of your landscape.</p>
            </div>
            <div class="intro-image">
                <img src="/images/rivver.jpg" alt="Pistol River Tree Service" class="rounded-image">
            </div>
        </div>

        <!-- Services List -->
        <div class="content-container">
            <h2>Our Tree Services in Pistol River, OR</h2>
            <ul>
                <li>Tree Removal</li>
                <li>Tree Trimming & Pruning</li>
                <li>Stump Grinding</li>
                <li>Emergency Tree Services</li>
                <li>View Clearing & Fire Reduction</li>
            </ul>
        </div>

        <!-- Contact Info -->
        <div class="contact-info-box">
            <h3>Get a Free Tree Service Estimate</h3>
            <p>
                <i class="fas fa-phone-alt"></i> Office: <a href="tel:<%= sitePhone %>"><%= sitePhone %></a><br>
                <i class="fas fa-mobile-alt"></i> Cell/Text: <a href="tel:<%= siteCell %>"><%= siteCell %></a><br>
                <i class="fas fa-envelope"></i> Email: <a href="mailto:<%= siteEmail %>"><%= siteEmail %></a>
            </p>
        </div>
    </div>
</section>