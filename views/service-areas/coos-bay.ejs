<%
// Coos Bay Service Area
%>

<!-- Page Header -->
<section class="page-header" style="background-image: url('/images/home.jpeg');">
    <div class="overlay"></div>
    <div class="container">
        <h1>Tree Service in Coos Bay, OR</h1>
        <p>Professional Tree Removal & Tree Care Services</p>
    </div>
</section>

<!-- Main Content -->
<section class="area-content section-padding">
    <div class="container">
        <!-- Intro with Image -->
        <div class="service-intro">
            <div class="intro-text">
                <p>JT & Sons Tree Service LLC proudly offers professional tree services in Coos Bay, OR for residential and commercial properties. Our experienced team specializes in tree removal, tree trimming, stump grinding, emergency tree services, and fire reduction throughout the Southern Oregon Coast.</p>
                <p>Large trees and seasonal storms in the Coos Bay area can create hazards for homes and properties. Our skilled crew provides safe and reliable tree care, helping property owners maintain healthy trees and safe landscapes.</p>
            </div>
            <div class="intro-image">
                <img src="/images/coos-bay.jpg" alt="Coos Bay Tree Service" class="rounded-image">
            </div>
        </div>

        <!-- Services List -->
        <div class="content-container">
            <h2>Our Tree Services in Coos Bay, OR</h2>
            <ul>
                <li><strong>Tree Removal</strong> – Safe removal of hazardous or storm-damaged trees.</li>
                <li><strong>Tree Trimming</strong> – Professional pruning to improve tree health.</li>
                <li><strong>Stump Grinding</strong> – Remove unsightly stumps and restore your yard.</li>
                <li><strong>Emergency Tree Services</strong> – Fast storm cleanup and tree removal.</li>
                <li><strong>View Clearing & Fire Reduction</strong> – Reduce wildfire risk and improve views.</li>
            </ul>
        </div>

        <!-- Contact Info -->
        <div class="contact-info-box">
            <h3>Call today for a free estimate</h3>
            <p>
                <i class="fas fa-phone-alt"></i> Office: <a href="tel:<%= sitePhone %>"><%= sitePhone %></a><br>
                <i class="fas fa-mobile-alt"></i> Cell/Text: <a href="tel:<%= siteCell %>"><%= siteCell %></a><br>
                <i class="fas fa-envelope"></i> Email: <a href="mailto:<%= siteEmail %>"><%= siteEmail %></a>
            </p>
        </div>
    </div>
</section>