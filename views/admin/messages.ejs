
<div class="messages">
    <h1>Contact Messages</h1>
    <table class="data-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Email</th>
                <th>Phone</th>
                <th>Message</th>
                <th>Received</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (messages.length === 0) { %>
                <tr><td colspan="7" class="text-center">No messages found</td></tr>
            <% } %>
            <% messages.forEach(msg => { %>
            <tr>
                <td><%= msg.id %></td>
                <td><%= msg.name %></td>
                <td><a href="mailto:<%= msg.email %>"><%= msg.email %></a></td>
                <td><%= msg.phone || '—' %></td>
                <td><%= msg.message.substring(0, 50) %><%= msg.message.length > 50 ? '…' : '' %></td>
                <td><%= new Date(msg.created_at).toLocaleDateString() %></td>
                <td>
                    <form action="/admin/messages/<%= msg.id %>/delete" method="POST" onsubmit="return confirm('Delete this message?')">
                        <button type="submit" class="btn-delete"><i class="fas fa-trash"></i></button>
                    </form>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>