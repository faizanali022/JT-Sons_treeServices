<%
// Gold Beach Service Area
%>

<!-- Page Header -->
<section class="page-header" style="background-image: url('/images/mg.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <h1>Tree Service in Gold Beach, OR</h1>
        <p>Professional Tree Removal, Tree Trimming & Fire Reduction</p>
    </div>
</section>

<!-- Main Content -->
<section class="area-content section-padding">
    <div class="container">
        <!-- Intro with Image -->
        <div class="service-intro">
            <div class="intro-text">
                <p>JT & Sons Tree Service LLC proudly provides reliable and professional tree services in Gold Beach, OR and throughout Curry County. As a family-owned and operated company with over 30 years of experience, we specialize in tree removal, tree trimming, stump grinding, emergency services, and fire reduction for residential and commercial properties.</p>
                <p>Gold Beach is known for its beautiful coastal views and large mature trees. Storms, strong coastal winds, and aging trees can create safety risks. Our experienced team provides safe and efficient tree care, helping property owners maintain healthy trees while protecting their homes.</p>
            </div>
            <div class="intro-image">
                <img src="/images/gold-beach1.jpg" alt="Gold Beach Tree Service" class="rounded-image">
            </div>
        </div>

        <!-- Services List -->
        <div class="content-container">
            <h2>Our Tree Services in Gold Beach, OR</h2>
            <ul>
                <li><strong>Tree Removal</strong> – Safe removal of dead, damaged, or hazardous trees.</li>
                <li><strong>Tree Trimming & Pruning</strong> – Professional pruning to improve tree health and safety.</li>
                <li><strong>Stump Grinding</strong> – Complete stump removal for a cleaner landscape.</li>
                <li><strong>Emergency Tree Services</strong> – Fast storm damage cleanup and hazardous tree removal.</li>
                <li><strong>View Clearing & Fire Reduction</strong> – Maintain scenic views while reducing wildfire risk.</li>
            </ul>
        </div>

        <!-- Contact Info -->
        <div class="contact-info-box">
            <h3>Contact Us for a Free Estimate</h3>
            <p>
                <i class="fas fa-phone-alt"></i> Office: <a href="tel:<%= sitePhone %>"><%= sitePhone %></a><br>
                <i class="fas fa-mobile-alt"></i> Cell/Text: <a href="tel:<%= siteCell %>"><%= siteCell %></a><br>
                <i class="fas fa-envelope"></i> Email: <a href="mailto:<%= siteEmail %>"><%= siteEmail %></a>
            </p>
        </div>
    </div>
</section>