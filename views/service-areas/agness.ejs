<%
// Agness Service Area
%>

<!-- Page Header -->
<section class="page-header" style="background-image: url('/images/gold-beach.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <h1>Tree Service in Agness, OR</h1>
        <p>Trusted Tree Removal & Tree Trimming Services</p>
    </div>
</section>

<!-- Main Content -->
<section class="area-content section-padding">
    <div class="container">
        <!-- Intro with Image -->
        <div class="service-intro">
            <div class="intro-text">
                <p>JT & Sons Tree Service LLC offers professional tree services in Agness, OR and surrounding Curry County communities. With decades of experience, we provide safe and reliable tree removal, tree trimming, stump grinding, emergency tree services, and fire reduction solutions.</p>
                <p>Agness properties often feature large trees and forested landscapes that require professional care. Our team provides expert tree care services to keep properties safe while maintaining the natural beauty of the area.</p>
            </div>
            <div class="intro-image">
                <img src="/images/agness-1.jpg" alt="Agness Tree Service" class="rounded-image">
            </div>
        </div>

        <!-- Services List -->
        <div class="content-container">
            <h2>Our Tree Services in Agness, OR</h2>
            <ul>
                <li>Tree Removal</li>
                <li>Tree Trimming & Pruning</li>
                <li>Stump Grinding</li>
                <li>Emergency Tree Services</li>
                <li>View Clearing & Fire Reduction</li>
            </ul>
            <p>Whether you need hazardous tree removal or routine tree trimming in Agness OR, our experienced crew is ready to help.</p>
        </div>

        <!-- Contact Info -->
        <div class="contact-info-box">
            <h3>Call today for a free estimate</h3>
            <p>
                <i class="fas fa-phone-alt"></i> Office: <a href="tel:<%= sitePhone %>"><%= sitePhone %></a><br>
                <i class="fas fa-mobile-alt"></i> Cell/Text: <a href="tel:<%= siteCell %>"><%= siteCell %></a><br>
                <i class="fas fa-envelope"></i> Email: <a href="mailto:<%= siteEmail %>"><%= siteEmail %></a>
            </p>
        </div>
    </div>
</section>