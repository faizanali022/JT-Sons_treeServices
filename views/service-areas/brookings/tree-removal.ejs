// Brookings Tree Removal
%>

<!-- Page Header -->
<section class="page-header" style="background-image: url('/images/tree-removal.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <h1>Tree Removal in Brookings, OR</h1>
        <p>Safe & Professional Tree Removal Services</p>
    </div>
</section>

<!-- Main Content -->
<section class="area-service-content section-padding">
    <div class="container">
        <!-- Intro with Image -->
        <div class="service-intro">
            <div class="intro-text">
                <p>JT & Sons Tree Service LLC provides professional tree removal services in Brookings, OR for homeowners and businesses across the Southern Oregon Coast.</p>
                <p>Trees can become hazardous due to storm damage, disease, structural weakness, or age. Our experienced crew specializes in safe and efficient tree removal using professional equipment and proven techniques. We handle everything from small tree removal to large hazardous removals near homes, structures, and power lines.</p>
            </div>
            <div class="intro-image">
                <img src="/images/tree-romove1.jpg" alt="Tree Removal in Brookings" class="rounded-image">
            </div>
        </div>

        <!-- Services List -->
        <div class="content-container">
            <h2>Our Tree Removal Services in Brookings Include:</h2>
            <ul>
                <li>Hazardous tree removal</li>
                <li>Dead tree removal</li>
                <li>Storm-damaged tree removal</li>
                <li>Large tree removal</li>
                <li>Tree removal near homes or structures</li>
            </ul>
            <p>If you're searching for tree removal near Brookings OR, JT & Sons Tree Service LLC offers dependable service and free estimates.</p>
        </div>

        <!-- Contact Info -->
        <div class="contact-info-box">
            <h3>Call today for a free estimate</h3>
            <p>
                <i class="fas fa-phone-alt"></i> Office: <a href="tel:<%= sitePhone %>"><%= sitePhone %></a><br>
                <i class="fas fa-mobile-alt"></i> Cell/Text: <a href="tel:<%= siteCell %>"><%= siteCell %></a>
            </p>
        </div>
    </div>
</section>