<%
// Bandon Service Area
%>

<!-- Page Header -->
<section class="page-header" style="background-image: url('/images/bandon1.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <h1>Tree Service in Bandon, OR</h1>
        <p>Expert Tree Removal, Trimming & Stump Grinding</p>
    </div>
</section>

<!-- Main Content -->
<section class="area-content section-padding">
    <div class="container">
        <!-- Intro with Image -->
        <div class="service-intro">
            <div class="intro-text">
                <p>JT & Sons Tree Service LLC provides professional tree services in Bandon, OR and nearby coastal communities. With 30+ years of experience, our team delivers safe and efficient tree removal, tree trimming, stump grinding, emergency tree services, and fire reduction.</p>
                <p>Bandon's coastal climate and mature trees often require routine maintenance to prevent storm damage and falling branches. Our team offers expert tree care to keep your property safe and beautiful.</p>
            </div>
            <div class="intro-image">
                <img src="/images/bandon.jpg" alt="Bandon Tree Service" class="rounded-image">
            </div>
        </div>

        <!-- Services List -->
        <div class="content-container">
            <h2>Our Tree Services in Bandon, OR</h2>
            <ul>
                <li>Tree Removal</li>
                <li>Tree Trimming & Pruning</li>
                <li>Stump Grinding</li>
                <li>Emergency Tree Services</li>
                <li>View Clearing & Fire Reduction</li>
            </ul>
            <p>If you're searching for tree service near Bandon OR, JT & Sons Tree Service LLC is the trusted company to call.</p>
        </div>

        <!-- Contact Info -->
        <div class="contact-info-box">
            <h3>Call today for a free estimate</h3>
            <p>
                <i class="fas fa-phone-alt"></i> Office: <a href="tel:<%= sitePhone %>"><%= sitePhone %></a><br>
                <i class="fas fa-mobile-alt"></i> Cell/Text: <a href="tel:<%= siteCell %>"><%= siteCell %></a><br>
                <i class="fas fa-envelope"></i> Email: <a href="mailto:<%= siteEmail %>"><%= siteEmail %></a>
            </p>
        </div>
    </div>
</section>