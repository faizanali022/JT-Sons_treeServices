<%
// Complete Homepage - All Sections Included
%>

<!-- Hero Section -->
<section class="hero" style="background-image: url('/images/hero-bg.jpg');">
    <div class="hero-overlay"></div>
    <div class="container">
        <div class="hero-content">
            <h1>Expert Tree Care for Your Southern Oregon Property</h1>
            <p>Family-Owned | Licensed & Insured | Free Estimates</p>
            <div class="hero-buttons">
               <a href="tel:<%= sitePhone %>" class="btn btn-primary"><i class="fas fa-phone-alt"></i> Call Now: <%= sitePhone %></a>
                <a href="/services" class="btn btn-secondary">Our Services</a>
            </div>
            
                
        
    </div>
</section>

<!-- Certifications Section -->
<!-- Certifications Section -->
<section class="certifications section-padding-sm">
    <div class="container">
        <h2 class="text-center">OUR CERTIFICATIONS & CREDENTIALS</h2>
        <div class="cert-grid">
            <div class="cert-item">
                <i class="fas fa-bolt"></i>
                <span>Powerline Clearance Certified</span>
                <small>OSHA & Utility Standards</small>
            </div>
            <div class="cert-item">
                <i class="fas fa-file-contract"></i>
                <span>Licensed, Insured & Bonded</span>
                <small>CCB #247528</small>
            </div>
            <div class="cert-item">
                <i class="fas fa-tree"></i>
                <span>30+ Years Experience</span>
                <small>Family-Owned Since 1990</small>
            </div>
            <div class="cert-item">
                <i class="fas fa-shield-alt"></i>
                <span>ISA Certified Arborist</span>
                <small>On Every Job Site</small>
            </div>
        </div>
    </div>
</section>

<!-- About Section with Image Overlap -->
<section class="about-highlight section-padding">
    <div class="container">
        <div class="about-grid">
            <div class="about-image">
                <div class="image-wrapper">
                    <img src="/images/about-team.jpg" alt="JT & Sons Tree Service Team">
                    <div class="orange-block"></div>
                </div>
            </div>
            <div class="about-content">
                <h2>About jt & sons</h2>
                <h3>TRUSTED TREE & POWERLINE EXPERTS IN OREGON</h3>
                <p>JT & Sons Tree Service is a locally owned and operated company serving Oregon with professional tree removal and powerline clearance services. Our certified crew is fully licensed and insured, using modern equipment to deliver safe, reliable, and efficient service on every job.</p>
                <a href="/about" class="btn btn-primary">Learn more</a>
            </div>
        </div>
    </div>
</section>

<!-- Services Overview -->
<section class="services-overview section-padding bg-light">
    <div class="container">
        <h2 class="text-center">Our Professional Tree Services</h2>
        <div class="services-grid">
            <div class="service-card" style="background-image: url('/images/tree-removal.jpg');">
                <div class="card-content">
                    <h3>Tree Removal</h3>
                    <p>Safe removal of hazardous, dead, or unwanted trees.</p>
                    <a href="/services/tree-removal" class="btn-link">Learn More <i class="fas fa-arrow-right"></i></a>
                </div>
            </div>
            <div class="service-card" style="background-image: url('/images/tree-trimming.jpg');">
                <div class="card-content">
                    <h3>Tree Trimming</h3>
                    <p>Expert pruning and shaping for healthy, beautiful trees.</p>
                    <a href="/services/tree-trimming" class="btn-link">Learn More <i class="fas fa-arrow-right"></i></a>
                </div>
            </div>
            <div class="service-card" style="background-image: url('/images/stump-grinding.jpg');">
                <div class="card-content">
                    <h3>Stump Grinding</h3>
                    <p>Complete stump removal for a clean landscape.</p>
                    <a href="/services/stump-grinding" class="btn-link">Learn More <i class="fas fa-arrow-right"></i></a>
                </div>
            </div>
         
        </div>
        <div class="text-center" style="margin-top: 40px;">
            <a href="/services" class="btn btn-primary">View All Services</a>
        </div>
    </div>
</section>

<!-- Why Choose Us -->
<section class="why-choose section-padding">
    <div class="container">
        <h2 class="text-center">Why Choose JT & Sons?</h2>
        <div class="features-grid">
            <div class="feature">
                <i class="fas fa-tree"></i>
                <h3>30+ Years Experience</h3>
            </div>
            <div class="feature">
                <i class="fas fa-users"></i>
                <h3>Family Owned</h3>
            </div>
            <div class="feature">
                <i class="fas fa-bolt"></i>
                <h3>Powerline Certified</h3>
            </div>
            <div class="feature">
                <i class="fas fa-file-contract"></i>
                <h3>Licensed & Insured</h3>
            </div>
            <div class="feature">
                <i class="fas fa-map-marker-alt"></i>
                <h3>Serving Curry County</h3>
            </div>
            <div class="feature">
                <i class="fas fa-calculator"></i>
                <h3>Free Estimates</h3>
            </div>
        </div>
    </div>
</section>

<!-- Service Areas Grid -->
<section class="service-areas section-padding bg-light">
    <div class="container">
        <h2 class="text-center">Areas We Serve</h2>
        <div class="areas-grid">
            <a href="/service-areas/gold-beach" class="area-card" style="background-image: url('/images/gold-beach.jpg');">
                <div class="card-overlay">
                    <h3>Gold Beach</h3>
                </div>
            </a>
            <a href="/service-areas/brookings" class="area-card" style="background-image: url('/images/brookings.jpg');">
                <div class="card-overlay">
                    <h3>Brookings</h3>
                </div>
            </a>
            <a href="/service-areas/pistol-river" class="area-card" style="background-image: url('/images/pistol-river.jpg');">
                <div class="card-overlay">
                    <h3>Pistol River</h3>
                </div>
            </a>
            <a href="/service-areas/port-orford" class="area-card" style="background-image: url('/images/port-orford.jpg');">
                <div class="card-overlay">
                    <h3>Port Orford</h3>
                </div>
            </a>
            <a href="/service-areas/bandon" class="area-card" style="background-image: url('/images/bandon.jpg');">
                <div class="card-overlay">
                    <h3>Bandon</h3>
                </div>
            </a>
            <a href="/service-areas/coos-bay" class="area-card" style="background-image: url('/images/coos-bay.jpg');">
                <div class="card-overlay">
                    <h3>Coos Bay</h3>
                </div>
            </a>
        </div>
    </div>
</section>

<!-- Question / Contact Form Section -->
<section class="contact-form-section section-padding">
    <div class="container">
        <div class="form-container">
            <h2 class="text-center">Have a Question? Ask Us!</h2>
            <p class="text-center">We're here to help. Send us a message and we'll get back to you soon.</p>
            <form action="/contact" method="POST" class="contact-form">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="name">Name *</label>
                        <input type="text" id="name" name="name" required>
                    </div>
                    <div class="form-group">
                        <label for="email">Email *</label>
                        <input type="email" id="email" name="email" required>
                    </div>
                    <div class="form-group full-width">
                        <label for="message">Message *</label>
                        <textarea id="message" name="message" rows="5" required></textarea>
                    </div>
                </div>
                <button type="submit" class="btn btn-primary btn-block">Send Message</button>
            </form>
        </div>
    </div>
</section>
<!-- Reviews Section -->
<section class="reviews section-padding bg-light">
    <div class="container">
        <h2 class="text-center">What Our Customers Say</h2>
        <div class="reviews-grid">
            <% 
            const reviews = [
                {
                    name: "Deidre Hagen",
                    rating: 5,
                    date: "a month ago",
                    text: "JT, Talon and crew did an exceptional job in removing overgrown trees, vines and shrubs from our lot. They hauled everything away and left us with a new vision for building. Super friendly folks to work with. Will be hiring them again! Thank you guys for a great experience for these out of towners. D&D Hagen",
                    authorDetail: "D&D Hagen",
                    photos: 6,
                    isLocalGuide: false,
                    reviewCount: 6
                },
                {
                    name: "Pat Murphy",
                    rating: 5,
                    date: "a year ago",
                    text: "This is a family run, local business. Grandpa, JT, & his sons were all here & participated in cutting down and removing a dead tree. I was amazed at their in depth knowledge of tree health and diagnosing the cause of the tree death. They were all very personable and professional. Considering the hazards involved, they were also very safety conscious. They quickly climbed the tree, trimmed branches, then cut it to make it fall in the direction they chose. They then cut it into smaller pieces and hauled it away. They finished by cleaning up the debris. It was if they never had been here, except for the missing tree! I highly recommend this family business. John Murphy",
                    authorDetail: "John Murphy",
                    photos: 13,
                    isLocalGuide: true,
                    reviewCount: 19
                },
                {
                    name: "Barbara Lezynski",
                    rating: 5,
                    date: "a year ago",
                    text: "We highly recommend JT & Sons Tree Service for their expertise and professionalism, their tree work is pure artistry. They always exceed expectations including taking time to explain the work they are going to do, showing up as promised and doing a great job. Year after year, the care and time taken shows because the trees are flourishing. Happy trees, happy us.",
                    authorDetail: "",
                    photos: 2,
                    isLocalGuide: false,
                    reviewCount: 10
                },
                {
                    name: "Jo Ann O'kane",
                    rating: 5,
                    date: "7 months ago",
                    text: "We've had the crew out multiple times and are always more than happy with the results. They are on time, hardworking and eager to please. They expertly handle everything from large trees to shrubs & brush while being mindful of any delicate landscaping. Most especially, they are very easy to work with. We highly recommend our friends at JT & Sons Tree Service!",
                    authorDetail: "",
                    photos: 0,
                    isLocalGuide: false,
                    reviewCount: 8
                },
                {
                    name: "Mary",
                    rating: 5,
                    date: "3 months ago",
                    text: "Great price. I highly recommend JT and Sons tree service. The crew was professional, friendly, and efficient. They also provided excellent customer service. I will definitely use their services again. Services: Tree removal",
                    authorDetail: "Services: Tree removal",
                    photos: 0,
                    isLocalGuide: false,
                    reviewCount: 1
                },
                {
                    name: "Debi Stuhr",
                    rating: 5,
                    date: "4 months ago",
                    text: "This was our third time having JT and Son's come to work on our property. They are always prompt, friendly and efficient. We would recommend them without hesitation! Thanks guys and see you next time round! Services: Tree trimming and pruning, Tree removal",
                    authorDetail: "Services: Tree trimming and pruning, Tree removal",
                    photos: 5,
                    isLocalGuide: false,
                    reviewCount: 1
                },
                {
                    name: "Larry Reed",
                    rating: 5,
                    date: "9 months ago",
                    text: "I finally have my spectacular view back, after years of brush blocking my scenery!!! And now my driveway is wide again, instead of just barely allowing my car through!! And most importantly for the safety of my house, JT & Sons removed a large tree that was leaning in a threatening way. The entire crew was very professional, and at the same time, very friendly. And they got everything done in one day!! I recommend them very, very highly!!",
                    authorDetail: "",
                    photos: 0,
                    isLocalGuide: false,
                    reviewCount: 2
                },
                {
                    name: "DL Foley",
                    rating: 5,
                    date: "9 months ago",
                    text: "Fantastic family run business specializing in almost everything green (i.e. trees, shrubs, storm debri, weed abatement, etc.). Extremely professional and a great experience from the time you schedule your work with Teresa, meeting with Jason and Talon for a very reasonable, knowledge based and thorough estimate , to the reliability and efficiency of their crew. They definitely have the 'no job is beneath us- happy to do it' attitude. Give them a try, you'll be happy you did!!!!!",
                    authorDetail: "",
                    photos: 0,
                    isLocalGuide: false,
                    reviewCount: 1
                }
            ];
            %>
            <% reviews.forEach(review => { %>
            <div class="review-card">
                <div class="review-header">
                    <div class="reviewer-avatar">
                        <i class="fas fa-user-circle"></i>
                    </div>
                    <div class="reviewer-info">
                        <h3><%= review.name %></h3>
                        <div class="review-meta">
                            <% if (review.isLocalGuide) { %>
                                <span class="badge local-guide"><i class="fas fa-check-circle"></i> Local Guide</span>
                            <% } %>
                            <span class="review-count"><%= review.reviewCount %> reviews</span>
                            <% if (review.photos > 0) { %>
                                <span class="photo-count"><i class="fas fa-camera"></i> <%= review.photos %> photos</span>
                            <% } %>
                        </div>
                    </div>
                </div>
                <div class="review-rating">
                    <% for(let i = 0; i < 5; i++) { %>
                        <i class="fas fa-star <%= i < review.rating ? 'star-filled' : 'star-empty' %>"></i>
                    <% } %>
                    <span class="review-date"><%= review.date %></span>
                </div>
                <p class="review-text">“<%= review.text %>”</p>
                <% if (review.authorDetail) { %>
                    <p class="review-author-detail"><%= review.authorDetail %></p>
                <% } %>
            </div>
            <% }) %>
        </div>
    </div>
</section>
<section class="recommendation-section">
    <div class="container">
        <div class="recommendation-content">
            <i class="fas fa-star recommendation-icon"></i>
            <div class="recommendation-text">
                <span class="recommendation-number">100+</span>
                <span class="recommendation-label">locals in Curry County recommend JT & Sons Tree Service</span>
            </div>
        </div>
    </div>
</section>

<!-- License Section (brief) -->
<section class="license bg-dark section-padding-sm">
    <div class="container text-center">
        <p><strong>CCB #<%= ccbLicense %></strong> | Licensed, Insured & Bonded | Powerline Clearance Certified</p>
    </div>
</section>
<!-- Recommendation Section -->
