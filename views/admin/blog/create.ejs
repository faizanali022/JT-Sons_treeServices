
<div class="blog-form">
    <h1>Create New Blog Post</h1>
    <% if (locals.error) { %>
        <div class="alert alert-error"><%= error %></div>
    <% } %>
    <form action="/admin/blog/create" method="POST" enctype="multipart/form-data">
        <div class="form-group">
            <label for="title">Title *</label>
            <input type="text" id="title" name="title" required>
        </div>
        <div class="form-group">
            <label for="excerpt">Excerpt (short summary)</label>
            <textarea id="excerpt" name="excerpt" rows="2"></textarea>
        </div>
        <div class="form-group">
            <label for="content">Content *</label>
            <textarea id="content" name="content" rows="12" required></textarea>
        </div>
        <div class="form-group">
            <label for="featured_image">Featured Image (Upload from Desktop) *</label>
            <input type="file" id="featured_image" name="featured_image" accept="image/jpeg,image/png,image/gif,image/webp" required>
            <small>Supported formats: JPEG, PNG, GIF, WebP | Max size: 5MB</small>
        </div>
        <div class="form-group">
            <label for="author">Author</label>
            <input type="text" id="author" name="author" value="JT & Sons">
        </div>
        <div class="form-group checkbox">
            <label>
                <input type="checkbox" name="published" checked> Publish immediately
            </label>
        </div>
        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Save Post</button>
            <a href="/admin/blog" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>