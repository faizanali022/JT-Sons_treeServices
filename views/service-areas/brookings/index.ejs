<%
// Brookings Main Page
%>

<!-- Page Header -->
<section class="page-header" style="background-image: url('/images/bbroking.jpg');">
    <div class="overlay"></div>
    <div class="container">
        <h1>Tree Service in Brookings, OR</h1>
        <p>Professional Tree Removal, Tree Trimming & Fire Reduction</p>
    </div>
</section>

<!-- Main Content -->
<section class="area-content section-padding">
    <div class="container">
        <!-- Intro with Image -->
        <div class="service-intro">
            <div class="intro-text">
                <p>JT & Sons Tree Service LLC proudly provides professional tree services in Brookings, OR and surrounding communities along the Southern Oregon Coast. With over 30 years of experience, our family-owned company specializes in tree removal, tree trimming, stump grinding, emergency services, and fire reduction for residential and commercial properties.</p>
                <p>Brookings is known for its beautiful coastal landscapes and mature trees. Strong coastal winds, storms, and overgrown vegetation can create hazards. Our experienced team provides safe and reliable tree care to maintain healthy trees and protect your property.</p>
            </div>
            <div class="intro-image">
                <img src="/images/brookings.jpg" alt="Brookings Tree Service" class="rounded-image">
            </div>
        </div>

        <!-- Services Links -->
        <div class="content-container">
            <h2>Our Tree Services in Brookings, OR</h2>
            <ul>
                <li><a href="/service-areas/brookings/tree-removal">Tree Removal</a></li>
                <li><a href="/service-areas/brookings/tree-trimming">Tree Trimming & Pruning</a></li>
                <li><a href="/service-areas/brookings/stump-grinding">Stump Grinding</a></li>
                <li><a href="/service-areas/brookings/emergency-tree">Emergency Tree Services</a></li>
                <li><a href="/service-areas/brookings/fire-reduction">View Clearing & Fire Reduction</a></li>
                <li><a href="/service-areas/brookings/crane-services">Crane Services</a></li>
            </ul>
        </div>

        <!-- Contact Info -->
        <div class="contact-info-box">
            <h3>Get a Free Tree Service Estimate in Brookings</h3>
            <p>
                <i class="fas fa-phone-alt"></i> Office: <a href="tel:<%= sitePhone %>"><%= sitePhone %></a><br>
                <i class="fas fa-mobile-alt"></i> Cell/Text: <a href="tel:<%= siteCell %>"><%= siteCell %></a><br>
                <i class="fas fa-envelope"></i> Email: <a href="mailto:<%= siteEmail %>"><%= siteEmail %></a>
            </p>
        </div>
    </div>
</section>